{
  "manifest_version": 3,
  "name": "Lovable Free Tools",
  "version": "1.2.0",
  "description": "Detecta projetos Lovable automaticamente e injeta o Debug Tool flutuante para disparar instruções via 'Try to Fix' sem usar o chat lateral.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.lovable.app/*",
    "https://*.lovableproject.com/*",
    "https://lovable.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lovable Free Tools"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
